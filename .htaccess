# Activar el motor de reescritura
RewriteEngine On

# 1. Proteger el archivo agents.md
<Files "agents.md">
    Order Allow,Deny
    Deny from all
</Files>

# 2. Proteger todo el directorio .git y sus subdirectorios
<DirectoryMatch "^.*\.git/">
    Order Allow,Deny
    Deny from all
</DirectoryMatch>

# Alternativa con RewriteRule (más eficiente y compatible)
# Bloquear cualquier ruta que contenga .git (incluyendo .git/HEAD, .git/config, etc.)
RewriteRule ^(.*\.git|\.git/.*)$ - [F,L]

# Opcional: también bloquear el acceso directo a .git como archivo (si alguien crea uno)
RewriteRule ^\.git$ - [F,L]

# Prevenir listado de directorios en general (opcional pero recomendado)
Options -Indexes